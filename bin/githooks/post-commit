#!/bin/sh

# Custom post-commit hook that runs the linter.

action() {
    # just lint
    if [ ! -d "${ST_ENTANGLEMENT_BASE}" ]; then
        >&2 echo "ST_ENTANGLEMENT_BASE not setup, skip linting"
    elif [ "${ST_ENTANGLEMENT_SKIP_POST_COMMIT}" != "1" ]; then
        echo "post-commit linting ..."
        bash "${ST_ENTANGLEMENT_BASE}/tests/run_linting"
        echo
    fi

    # always end successfully
    return "0"
}
action "$@"
